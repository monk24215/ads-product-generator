# Normalize line endings to LF on commit, regardless of OS
* text=auto eol=lf

# Explicitly mark common text files
*.js     text eol=lf
*.json   text eol=lf
*.md     text eol=lf
*.html   text eol=lf
*.css    text eol=lf
*.php    text eol=lf
*.txt    text eol=lf

# Binary files — never normalize, never diff as text
*.png    binary
*.jpg    binary
*.jpeg   binary
*.gif    binary
*.ico    binary
*.webp   binary
*.svg    binary
*.pdf    binary
*.zip    binary
*.woff   binary
*.woff2  binary
*.ttf    binary
*.eot    binary